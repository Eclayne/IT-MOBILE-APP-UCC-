    <color name="ucc_gold_dark">#CCA800</color>
    <color name="white">#FFFFFF</color>
    <dimen name="avatar_size">72dp</dimen>
    <dimen name="card_margin">12dp</dimen>
    <dimen name="card_padding">16dp</dimen>
    <dimen name="fab_margin">16dp</dimen>
    <dimen name="icon_size_menu">56dp</dimen>
    <dimen name="text_body">13sp</dimen>
    <dimen name="text_subtitle">14sp</dimen>
    <dimen name="text_title">18sp</dimen>
    <string name="admissions">Admissions</string>
    <string name="app_name">UCC IT Mobile App</string>
    <string name="courses">Courses</string>
    <string name="department_name">Department of Information Technology</string>
    <string name="email_hod">Email HOD</string>
    <string name="faculty_directory">Faculty/Staff Directory</string>
