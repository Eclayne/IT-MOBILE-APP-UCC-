<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.UCCITApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/ucc_blue</item>
        <item name="colorPrimaryVariant">@color/ucc_blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/ucc_gold</item>
        <item name="colorSecondaryVariant">@color/ucc_gold_dark</item>
        <item name="colorOnSecondary">@color/ucc_blue_dark</item>
        <item name="android:statusBarColor">@color/ucc_blue_dark</item>
        <item name="android:navigationBarColor">@color/ucc_blue</item>
    </style>

    <style name="Theme.UCCITApp.NoActionBar" parent="Theme.UCCITApp">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.UCCITApp.Splash" parent="Theme.UCCITApp.NoActionBar">
        <item name="android:windowBackground">@color/ucc_blue</item>
        <item name="android:statusBarColor">@color/ucc_blue</item>
    </style>

    <style name="CardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">6dp</item>
        <item name="cardUseCompatPadding">true</item>
    </style>

    <style name="MenuCardText">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
        <item name="android:gravity">center</item>
    </style>

</resources>
